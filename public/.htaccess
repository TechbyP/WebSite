RewriteEngine On

# Do not rewrite API-like paths to the SPA entry point.
RewriteRule ^(api|data)(/.*)?$ - [L]

# Serve real files and directories as-is.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Send all other routes to the React app.
RewriteRule . /index.html [L]
